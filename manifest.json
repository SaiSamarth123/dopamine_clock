{
  "manifest_version": 3,
  "name": "Memento",
  "version": "2.0.1",
  "description": "New tab accountability for your stated mission — life urgency, focus timer, and optional site friction.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Memento",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "tabs"
  ],
  "host_permissions": ["https://dev.to/*"]
}
