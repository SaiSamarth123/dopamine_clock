{
  "manifest_version": 3,
  "name": "Memento",
  "version": "0.0.0.1",
  "description": "New tab accountability for your stated mission — life urgency and focus timer.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Memento",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://dev.to/*"]
}
